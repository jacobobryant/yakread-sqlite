{:require
 [[com.yakread.lib.test :as t]
  [clojure.data.generators :as gen]
  [com.yakread.model.user.export :refer :all]],
 :tests
 [{:doc "feed-subs",
   :eval
   (t/with-sqlite
    [ctx
     {:sub
      [{:sub/id (t/uuid 1),
        :sub/user-id (t/uuid 100),
        :sub/feed-id (t/uuid 10)}],
      :feed [{:feed/id (t/uuid 10), :feed/url "url1"}]}]
    (t/resolve-resolver feed-subs ctx {:user/id (t/uuid 100)})),
   :result
   {:user.export/feed-subs
    "<?xml version=\"1.0\" encoding=\"UTF-8\"?>\n<opml version=\"1.0\">\n  <head><title>Yakread RSS subscriptions</title></head>\n  <body>\n    <outline type=\"rss\" xmlUrl=\"url1\"></outline>\n</body></opml>"}}
  _
  {:doc "bookmarks",
   :eval
   (t/with-sqlite
    [ctx
     {:user-item
      [{:user-item/id (t/uuid 11),
        :user-item/user-id (t/uuid 100),
        :user-item/bookmarked-at (t/instant 2000),
        :user-item/viewed-at (t/instant 2001),
        :user-item/item-id (t/uuid 1)}
       {:user-item/id (t/uuid 12),
        :user-item/user-id (t/uuid 100),
        :user-item/bookmarked-at (t/instant 2002),
        :user-item/viewed-at (t/instant 2003),
        :user-item/item-id (t/uuid 2)}
       {:user-item/id (t/uuid 13),
        :user-item/user-id (t/uuid 200),
        :user-item/bookmarked-at (t/instant 2002),
        :user-item/viewed-at (t/instant 2003),
        :user-item/item-id (t/uuid 3)}
       {:user-item/id (t/uuid 14),
        :user-item/user-id (t/uuid 100),
        :user-item/viewed-at (t/instant 2000),
        :user-item/item-id (t/uuid 4)}],
      :item
      (for
       [i [1 2 3 4]]
       {:item/id (t/uuid i),
        :item/url (str "url" i),
        :item/title (str "title" i),
        :item/author-name (str "author-name" i)})}]
    (t/resolve-resolver bookmarks ctx {:user/id (t/uuid 100)})),
   :result
   {:user.export/bookmarks
    "URL,Title,Author,Bookmarked at,Read at\nurl2,title2,author-name2,2002-01-01T00:00:00Z,2003-01-01T00:00:00Z\nurl1,title1,author-name1,2000-01-01T00:00:00Z,2001-01-01T00:00:00Z\n"}}
  _]}
