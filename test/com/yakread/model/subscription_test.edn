   :eval
   (t/with-sqlite
    [conn
     {:sub
      [{:xt/id (t/uuid 0), :sub/user-id (t/uuid 9)}
       {:xt/id (t/uuid 1),
        :sub/user-id (t/uuid 9),
        :sub/email-unsubscribed-at (t/zdt 2000)}
       {:xt/id (t/uuid 2), :sub/user-id (t/uuid 11)}]}]
