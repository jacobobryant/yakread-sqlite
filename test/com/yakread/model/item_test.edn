  {:eval
   (t/with-sqlite
    [ctx
     {:reclist
      [{:reclist/id (t/uuid 1), :reclist/user-id (t/uuid 10)}
       {:reclist/id (t/uuid 2), :reclist/user-id (t/uuid 10)}
       {:reclist/id (t/uuid 3), :reclist/user-id (t/uuid 20)}
       {:reclist/id (t/uuid 4), :reclist/user-id (t/uuid 10)}
       {:reclist/id (t/uuid 5), :reclist/user-id (t/uuid 10)}],
      :skip
      [{:skip/id (t/uuid 11),
