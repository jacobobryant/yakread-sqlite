  {:doc "image-from-feed",
   :eval
   (t/with-sqlite
    [ctx
     {:feed
      [{:feed/id (t/uuid 1),
        :feed/url "url1",
        :feed/image-url "image-url1"}
       {:feed/id (t/uuid 2),
        :feed/url "url2",
        :feed/image-url "image-url2"}]}]
    (image-from-feed
     ctx
     [{:item/feed-id {:feed/image-url "image-url3"}}
      {:item/feed-id {:feed/image-url "image-url4"},
       :item/feed-url "url1"}
      {:item/feed-url "url1"}
      {:item/feed-url "url3"}])),
   :result
   [{:item/image-url "image-url3"}
    {:item/image-url "image-url4"}
    {:item/image-url "image-url1"}
    {}]}
  _
  {:doc "history-items",
   :eval
   (t/with-sqlite
    [ctx
     {:user-item
      [{:user-item/id (t/uuid 1),
        :user-item/user-id (t/uuid 10),
        :user-item/item-id (t/uuid 100),
        :user-item/viewed-at (t/instant 2000)}
       {:user-item/id (t/uuid 2),
        :user-item/user-id (t/uuid 10),
        :user-item/item-id (t/uuid 200),
        :user-item/viewed-at (t/instant 1999),
        :user-item/favorited-at (t/instant 2001)}]}]
    {:all (history-items ctx {:session/user {:user/id (t/uuid 10)}}),
     :page-1
     (history-items
      (pco/with-node-params ctx {:batch-size 1})
      {:session/user {:user/id (t/uuid 10)}}),
     :page-2
     (history-items
      ctx
      {:session/user {:user/id (t/uuid 10)},
       :params/paginate-after (t/uuid 200)})}),
   :result
   {:all
    {:user/history-items
     [{:item/id #uuid "02000000-0000-0000-0000-000000000200",
       :item/user-item
       {:user-item/id #uuid "00020000-0000-0000-0000-000000000002"}}
      {:item/id #uuid "01000000-0000-0000-0000-000000000100",
       :item/user-item
       {:user-item/id #uuid "00010000-0000-0000-0000-000000000001"}}]},
    :page-1
    {:user/history-items
     [{:item/id #uuid "02000000-0000-0000-0000-000000000200",
       :item/user-item
       {:user-item/id #uuid "00020000-0000-0000-0000-000000000002"}}]},
    :page-2
    {:user/history-items
     [{:item/id #uuid "01000000-0000-0000-0000-000000000100",
       :item/user-item
       {:user-item/id
        #uuid "00010000-0000-0000-0000-000000000001"}}]}}}
