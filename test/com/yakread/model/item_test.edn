   :eval
   (t/with-sqlite
    [ctx
     {:sub
      [{:sub/id (t/uuid 1),
        :sub/user-id (t/uuid 10),
        :sub/feed-id (t/uuid 100)}
       {:sub/id (t/uuid 2),
        :sub/user-id (t/uuid 10),
        :sub/feed-id (t/uuid 200)}]}]
    (feed-sub
     (assoc ctx :session {:uid (t/uuid 10)})
     [{:item/feed-id (t/uuid 100)}])),
   :result
   [{:item/sub
     {:sub/id #uuid "00010000-0000-0000-0000-000000000001"}}]}
  _
  {:doc "email-sub",
   :eval (email-sub {:item/email-sub-id (t/uuid 3)}),
   :result
   {:item/sub {:sub/id #uuid "00030000-0000-0000-0000-000000000003"}}}
  _
  {:doc "digest-sends",
   :eval
   (t/with-sqlite
    [ctx
     {:digest
      [{:digest/id (t/uuid 1),
        :digest/user-id (t/uuid 10),
        :digest/ad-id (t/uuid 500)}
       {:digest/id (t/uuid 2),
        :digest/user-id (t/uuid 10),
        :digest/ad-id (t/uuid 500)}],
      :digest-item
      [{:digest-item/id (t/uuid 11),
        :digest-item/digest-id (t/uuid 1),
        :digest-item/item-id (t/uuid 200)}
       {:digest-item/id (t/uuid 12),
        :digest-item/digest-id (t/uuid 1),
        :digest-item/item-id (t/uuid 300)}
       {:digest-item/id (t/uuid 13),
        :digest-item/digest-id (t/uuid 1),
        :digest-item/item-id (t/uuid 400)}
       {:digest-item/id (t/uuid 14),
        :digest-item/digest-id (t/uuid 2),
        :digest-item/item-id (t/uuid 400)}]}]
    (digest-sends
     (assoc ctx :session {:uid (t/uuid 10)})
     [{:item/id (t/uuid 100)}
      {:item/id (t/uuid 200)}
      {:item/id (t/uuid 300)}
      {:item/id (t/uuid 400)}
      {:item/id (t/uuid 600)}
      {:item/id (t/uuid 500)}
      {:item/id (t/uuid 700)}])),
   :result
   [{:item/id #uuid "01000000-0000-0000-0000-000000000100",
     :item/n-digest-sends 0}
    {:item/id #uuid "02000000-0000-0000-0000-000000000200",
     :item/n-digest-sends 1}
    {:item/id #uuid "03000000-0000-0000-0000-000000000300",
     :item/n-digest-sends 1}
    {:item/id #uuid "04000000-0000-0000-0000-000000000400",
     :item/n-digest-sends 2}
    {:item/id #uuid "06000000-0000-0000-0000-000000000600",
     :item/n-digest-sends 0}
    {:item/id #uuid "05000000-0000-0000-0000-000000000500",
