  [clojure.data.generators :as gen]
  [com.yakread.model.item :refer :all]
  [com.wsscode.pathom3.connect.operation :as pco]],
 :tests
 [{:eval
   (t/with-sqlite
    [ctx
     {:user-item
      [{:user-item/id (t/uuid 1),
