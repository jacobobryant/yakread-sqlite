{:require
 [[com.yakread.model.recommend :refer :all]
  [com.yakread.lib.test :as t]
  [clojure.data.generators :as gen]],
 :tests
 [{:eval (take-rand [1]), :result (1)}
  _
  {:eval (weight 0), :result 1.0}
  _
  {:eval (weight 1), :result 0.9355069850316178}
  _
  {:eval (weight 5), :result 0.7165313105737893}
  _
  {:eval (weight 10), :result 0.513417119032592}
  _
  {:eval (weight 50), :result 0.03567399334725241}
  _
  {:eval (weight 100), :result 0.0012726338013398079}
  _
  {:eval
   (let
    [weights (mapv weight (range 100)) total (apply + weights)]
    [(/ (apply + (take 10 weights)) total)
     (/ (apply + (take 50 weights)) total)]),
   :result [0.4872029118611535 0.965554804333789]}
  _
  {:eval
   (binding
    [gen/*rnd* (java.util.Random. 3)]
    (doall (interleave-uniform [:a :b :c :d] [1 2 3 4 5]))),
   :result (1 2 3 :a :b 4 :c :d 5)}
  _
  {:eval
   (t/with-sqlite
    [ctx
     {:skip
      [{:skip/id (t/uuid 31),
        :skip/reclist-id (t/uuid 21),
        :skip/item-id (t/uuid 11)}
       {:skip/id (t/uuid 32),
        :skip/reclist-id (t/uuid 21),
        :skip/item-id (t/uuid 12)}
       {:skip/id (t/uuid 33),
        :skip/reclist-id (t/uuid 22),
        :skip/item-id (t/uuid 14)}],
      :reclist
      [{:reclist/id (t/uuid 21),
        :reclist/user-id (t/uuid 1),
        :reclist/created-at (t/instant 2000),
        :reclist/clicked #{}}
       {:reclist/id (t/uuid 22),
        :reclist/user-id (t/uuid 1),
        :reclist/created-at (t/instant 2002),
        :reclist/clicked #{}}],
      :user-item
      [{:user-item/id (t/uuid 41),
        :user-item/item-id (t/uuid 13),
        :user-item/user-id (t/uuid 1),
        :user-item/favorited-at (t/instant 2001)}
       {:user-item/id (t/uuid 42),
        :user-item/item-id (t/uuid 15),
        :user-item/user-id (t/uuid 1),
        :user-item/viewed-at (t/instant 2003)}]}]
    (t/resolve-resolver
     sub-affinity*
     ctx
     [{:sub/user-id (t/uuid 1),
       :sub/title "my sub",
       :sub/id (t/uuid 51),
       :sub/items
       [{:item/id (t/uuid 11)}
        {:item/id (t/uuid 12)}
        {:item/id (t/uuid 13)}]}
      {:sub/user-id (t/uuid 1),
       :sub/title "my other sub",
       :sub/id (t/uuid 52),
       :sub/items [{:item/id (t/uuid 14)} {:item/id (t/uuid 15)}]}])),
   :result
   [{:sub/n-interactions 3,
     :sub/new false,
     :sub/user-id #uuid "00010000-0000-0000-0000-000000000001",
     :sub/affinity-low* 0.6287594284880811,
     :sub/title "my sub",
     :sub/affinity-high* 0.8861517686835451,
     :sub/id #uuid "00510000-0000-0000-0000-000000000051",
     :sub/scores (10.0 -0.9355069850316178 -0.8751733190429475),
     :sub/items
     [{:item/id #uuid "00110000-0000-0000-0000-000000000011"}
      {:item/id #uuid "00120000-0000-0000-0000-000000000012"}
      {:item/id #uuid "00130000-0000-0000-0000-000000000013"}],
     :sub/all-interactions
     ({:action :skipped, :t #time/instant "2000-01-01T00:00:00Z"}
      {:action :skipped, :t #time/instant "2000-01-01T00:00:00Z"}
      {:action :favorited, :t #time/instant "2001-01-01T00:00:00Z"})}
    {:sub/n-interactions 2,
     :sub/new false,
     :sub/user-id #uuid "00010000-0000-0000-0000-000000000001",
     :sub/affinity-low* 0.27354641067767876,
     :sub/title "my other sub",
     :sub/affinity-high* 0.872047711040352,
     :sub/id #uuid "00520000-0000-0000-0000-000000000052",
     :sub/scores (2.0 -0.9355069850316178),
     :sub/items
     [{:item/id #uuid "00140000-0000-0000-0000-000000000014"}
      {:item/id #uuid "00150000-0000-0000-0000-000000000015"}],
     :sub/all-interactions
     ({:action :skipped, :t #time/instant "2002-01-01T00:00:00Z"}
      {:action :viewed, :t #time/instant "2003-01-01T00:00:00Z"})}]}
  _
  {:eval
   (binding
    [gen/*rnd* (java.util.Random. 0)]
    (t/resolve-resolver
     for-you-sub-recs
     {}
     {:user/selected-subs
      [{:item/rec-type :item.rec-type/subscription,
        :sub/title "sub1",
        :sub/unread-items
        [{:item/id "item1",
          :item/ingested-at (t/instant 2000),
          :item/n-skipped 10}
         {:item/id "item2",
          :item/ingested-at (t/instant 2001),
          :item/n-skipped 1}]}
       {:item/rec-type :item.rec-type/subscription,
        :sub/title "sub2",
        :sub/unread-items []}]})),
   :result
   {:user/for-you-sub-recs
    [{:item/id "item1",
      :item/ingested-at #time/instant "2000-01-01T00:00:00Z",
      :item/n-skipped 10,
      :item/rec-type :item.rec-type/subscription}]}}
  _
  {:eval
   (binding
    [gen/*rnd* (java.util.Random. 0)]
    (t/resolve-resolver
     icymi-sub-recs
     {}
     {:user/selected-subs
      [{:item/rec-type :item.rec-type/subscription,
        :sub/title "sub1",
        :sub/unread-items
        [{:item/id "item1",
          :item/ingested-at (t/instant 2000),
          :item/n-skipped 10}
         {:item/id "item2",
          :item/ingested-at (t/instant 2001),
          :item/n-skipped 1}]}
       {:item/rec-type :item.rec-type/subscription,
        :sub/title "sub2",
        :sub/unread-items []}],
      :user/digest-sub-items [{:item/id "item1"}]})),
   :result
   {:user/icymi-sub-recs
    [{:item/id "item2",
      :item/ingested-at #time/instant "2001-01-01T00:00:00Z",
      :item/n-skipped 1,
      :item/rec-type :item.rec-type/subscription}]}}
  _
  {:eval
   (binding
    [gen/*rnd* (java.util.Random. 0)]
    (t/resolve-resolver
     icymi-bookmark-recs
     {}
     {:user/digest-bookmarks [{:item/id "item1"} {:item/id "item2"}],
      :user/unread-bookmarks
      [{:item/id "item1",
        :item/ingested-at (t/instant 2000),
        :item/n-skipped-with-digests 0}
       {:item/id "item2",
        :item/ingested-at (t/instant 2000),
        :item/n-skipped-with-digests 0}
       {:item/id "item3",
        :item/ingested-at (t/instant 2000),
        :item/n-skipped-with-digests 0,
        :item/url "https://example.com/article1"}
       {:item/id "item4",
        :item/ingested-at (t/instant 2000),
        :item/n-skipped-with-digests 0,
        :item/url "https://example.com/article2"}]})),
   :result
   {:user/icymi-bookmark-recs
    [{:item/id "item4",
      :item/ingested-at #time/instant "2000-01-01T00:00:00Z",
      :item/n-skipped-with-digests 0,
      :item/url "https://example.com/article2",
      :item/rec-type :item.rec-type/bookmark}]}}
  _
  {:eval
   (let
    [item
     (fn
      [i]
      {:item/id (str "item" i),
       :item/ingested-at (t/instant (+ 2000 i)),
       :item/n-skipped i})]
    (binding
     [gen/*rnd* (java.util.Random. 0)]
     (t/resolve-resolver
      icymi-recs
      {}
      {:user/icymi-bookmark-recs (mapv item (range 4 7)),
       :user/icymi-sub-recs (mapv item (range 1 4))}))),
   :result
   {:user/icymi-recs
    [{:item/id "item4",
      :item/ingested-at #time/instant "2004-01-01T00:00:00Z",
      :item/n-skipped 4}
     {:item/id "item2",
      :item/ingested-at #time/instant "2002-01-01T00:00:00Z",
      :item/n-skipped 2}
     {:item/id "item3",
      :item/ingested-at #time/instant "2003-01-01T00:00:00Z",
      :item/n-skipped 3}
     {:item/id "item5",
      :item/ingested-at #time/instant "2005-01-01T00:00:00Z",
      :item/n-skipped 5}
     {:item/id "item1",
      :item/ingested-at #time/instant "2001-01-01T00:00:00Z",
      :item/n-skipped 1}]}}
  _
  {:doc "read-urls",
   :eval
   (t/with-sqlite
    [ctx
     {:item
      [{:item/id (t/uuid 1), :item/url "url1"}
       {:item/id (t/uuid 2), :item/url "url2"}],
      :user-item
      [{:user-item/id (t/uuid 11),
        :user-item/user-id (t/uuid 100),
        :user-item/item-id (t/uuid 1)}
       {:user-item/id (t/uuid 12),
        :user-item/user-id (t/uuid 100),
        :user-item/item-id (t/uuid 2),
        :user-item/viewed-at (t/instant 2000)}]}]
    (t/resolve-resolver read-urls ctx {:user/id (t/uuid 100)})),
   :result {:user/read-urls #{"url2"}}}
  _
  {:doc "clicked-ads",
   :eval
   (t/with-sqlite
    [ctx
     {:ad-click
      [{:ad-click/id (t/uuid 1),
        :ad-click/ad-id (t/uuid 11),
        :ad-click/user-id (t/uuid 100)}
       {:ad-click/id (t/uuid 2),
        :ad-click/ad-id (t/uuid 12),
        :ad-click/user-id (t/uuid 200)}]}]
    (t/resolve-resolver clicked-ads ctx {:user/id (t/uuid 100)})),
   :result
   {:user/clicked-ads #{#uuid "00110000-0000-0000-0000-000000000011"}}}
  _]}
