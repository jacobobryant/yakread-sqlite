{:require
 [[com.yakread.lib.test :as t]
  [com.yakread.lib.sqlite :refer :all]
  [com.yakread.model.schema :as schema]],
 :tests
 [{:doc "make-resolvers creates resolvers from columns",
   :eval
   (let
    [resolvers (make-resolvers schema/columns)]
    (pos? (count resolvers))),
   :result true}
  _
  {:doc "make-resolvers resolver has batch true",
   :eval
   (let
    [resolvers
     (make-resolvers schema/columns)
     first-resolver
     (first resolvers)]
    (->
     first-resolver
     :biff.graph/batch)),
   :result true}
  _]}
