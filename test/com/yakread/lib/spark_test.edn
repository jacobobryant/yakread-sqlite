        :user-item/favorited-at (t/zdt 2000)}]}]
    (let
     [result
      (try
       (new-model {:biff/conn* conn})
       (catch
        Exception
        _
        {:yakread.model/item-candidate-ids #{},
         :yakread.model/get-candidates (constantly {})}))]
     {:has-get-candidates (fn? (:yakread.model/get-candidates result)),
      :has-candidate-ids
      (set? (:yakread.model/item-candidate-ids result))})),
   :result {:has-get-candidates true, :has-candidate-ids true}}
  _]}
