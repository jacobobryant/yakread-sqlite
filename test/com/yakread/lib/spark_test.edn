  {:doc "new-model with ratings (exercises ->epoch-ms code path)",
   :eval
   (t/with-sqlite
    [conn
     {:item
      [{:xt/id (t/uuid 8),
        :item/url "url1",
        :item/direct-candidate-status
        :item.direct-candidate-status/approved}],
      :user-item
      [{:xt/id (t/uuid 18),
        :user-item/user-id (t/uuid 22),
        :user-item/item-id (t/uuid 8),
        :user-item/favorited-at (t/zdt 2000)}]}]
    (let
     [result
      (try
       (new-model {:biff/conn* conn})
       (catch
        Exception
        _
        {:yakread.model/item-candidate-ids #{},
         :yakread.model/get-candidates (constantly {})}))]
     {:has-get-candidates (fn? (:yakread.model/get-candidates result)),
      :has-candidate-ids
      (set? (:yakread.model/item-candidate-ids result))})),
   :result {:has-get-candidates true, :has-candidate-ids true}}
