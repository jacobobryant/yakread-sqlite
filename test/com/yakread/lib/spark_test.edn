  {:doc "all-liked-items - empty database",
   :eval
   (t/with-sqlite [conn {}] (all-liked-items {:biff/conn* conn} {})),
   :result {:yakread.model/all-liked-items []}}
  _
  {:doc "all-liked-items",
   :eval
   (t/with-sqlite
    [conn
     {:user-item
      [{:xt/id "usit1",
        :user-item/item-id "item1",
        :user-item/favorited-at (t/zdt 2000)}
       {:xt/id "usit2",
        :user-item/item-id "item2",
        :user-item/favorited-at (t/zdt 2001)}
       {:xt/id "usit3",
        :user-item/item-id "item2",
        :user-item/favorited-at (t/zdt 2000)}
       {:xt/id "usit4", :user-item/item-id "item3"}]}]
    (all-liked-items {:biff/conn* conn} {})),
   :result
   {:yakread.model/all-liked-items
    [{:item/id "item2", :item/n-likes 2}
     {:item/id "item1", :item/n-likes 1}]}}
  _]}
