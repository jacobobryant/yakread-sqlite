  {:doc "extract-docs-from-txes extracts documents from XTDB v1 transactions"
   :eval
   (let [txes [{:xtdb.api/tx-time (java.time.Instant/parse "2024-01-15T12:00:00Z")
                :xtdb.api/tx-ops
                [[:xtdb.api/put
                  {:xt/id #uuid "00010000-0000-0000-0000-000000000001"
                   :user/email "test@example.com"}]
                 [:xtdb.api/put
                  {:xt/id #uuid "00020000-0000-0000-0000-000000000002"
                   :feed/url "https://example.com/feed.xml"}]
                 [:xtdb.api/delete #uuid "00030000-0000-0000-0000-000000000003"]]}]
         docs (extract-docs-from-txes txes)]
     {:count (count docs)
      :ids (set (map :xt/id docs))}),
   :result {:count 2,
            :ids #{#uuid "00010000-0000-0000-0000-000000000001"
                   #uuid "00020000-0000-0000-0000-000000000002"}}}
