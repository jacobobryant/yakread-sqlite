     :tx-count (count (:txs result))}),
   :result
   {:has-txs true, :has-state true, :has-tx-results true, :tx-count 2}}
  _
  {:doc "make-upsert-tx creates upsert transaction",
   :eval
   (let
    [tx
     (make-upsert-tx
      :user
      {:id (uuid->bytes #uuid "00010000-0000-0000-0000-000000000001"),
       :email "test@example.com",
       :nil-value nil})]
    {:type (:type tx),
     :table (:table tx),
     :row-keys (set (keys (:row tx)))}),
   :result {:type :upsert, :table :user, :row-keys #{:email :id}}}
  _
  {:doc "make-delete-tx creates delete transaction",
   :eval
   (let
    [tx
     (make-delete-tx
      :user
      (uuid->bytes #uuid "00010000-0000-0000-0000-000000000001"))]
    {:type (:type tx), :table (:table tx), :has-id (some? (:id tx))}),
   :result {:type :delete, :table :user, :has-id true}}
  _
  {:doc "sample-n returns all items when n >= count",
   :eval
   (let
    [items [1 2 3] sampled (sample-n 5 items)]
    {:count (count sampled), :all-present (= (set sampled) #{1 3 2})}),
   :result {:count 3, :all-present true}}
  _
  {:doc "sample-n returns n items when n < count",
   :eval
   (let
    [items [1 2 3 4 5] sampled (sample-n 3 items)]
    {:count (count sampled),
     :all-from-original (every? (set items) sampled)}),
   :result {:count 3, :all-from-original true}}
  _
  {:doc "group-txs-by-table groups transactions correctly",
   :eval
   (let
    [txs
     [{:type :upsert, :table :user, :row {:id 1}}
      {:type :upsert, :table :feed, :row {:id 2}}
      {:type :upsert, :table :user, :row {:id 3}}]
     grouped
     (group-txs-by-table txs)]
    {:tables (set (keys grouped)),
     :user-count (count (get grouped :user)),
     :feed-count (count (get grouped :feed))}),
   :result {:tables #{:feed :user}, :user-count 2, :feed-count 1}}
  _]}
