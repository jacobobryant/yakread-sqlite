{:require
 [[com.yakread.lib.test :as t]
  [clojure.data.generators :as gen]
  [com.yakread.work.train :refer :all]],
 :tests
 [{:eval
   (t/with-sqlite
    [ctx
     {:item
      [{:item/id (t/uuid 1), :item/url "https://example.com/1"}
       {:item/id (t/uuid 2), :item/url "https://example.com/2"}
       {:item/id (t/uuid 3),
        :item/url "https://example.com/2",
        :item/record-type [:lift :item.record-type/direct]}
       {:item/id (t/uuid 4), :item/url "https://example.com/4"}],
      :user-item
      [{:user-item/id (t/uuid 11),
        :user-item/item-id (t/uuid 1),
        :user-item/favorited-at (t/instant 2000)}
       {:user-item/id (t/uuid 12),
        :user-item/item-id (t/uuid 2),
        :user-item/favorited-at (t/instant 2000)}]}]
    (queue-add-candidate
     (merge
      ctx
      {:biff/queues
       {:work.train/add-candidate
        (java.util.concurrent.ConcurrentLinkedQueue.)},
       :yakread.work.queue-add-candidate/enabled true}))),
   :result
   {:biff.fx/queue
    [:biff.fx/queue
     {:jobs
      ([:work.train/add-candidate
        {:item/url "https://example.com/1"}])}]}}
  _]}
