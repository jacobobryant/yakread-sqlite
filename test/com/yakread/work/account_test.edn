      "yakread-export-1999-12-31-946684800000-00130000-0000-0000-0000-000000000013.zip"
      "yakread-export-1999-12-31-946684800000-00130000-0000-0000-0000-000000000013"
      :dir
      "/tmp/dir"]}
    {:biff.fx/delete-files
