         :sub/record-type [:lift :sub.record-type/email],
         :sub/created-at
         #time/zoned-date-time "2000-01-01T00:00Z[UTC]"}],
       :on-conflict [:sub/user-id :sub/feed-id :sub/email-from],
       :do-nothing true})}]}
