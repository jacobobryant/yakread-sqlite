{:require
 [[com.yakread.lib.test :as t]
  [clojure.data.generators :as gen]
  [com.biffweb.experimental :as biffx]
  [com.yakread.util.biff-staging :refer :all]
  [xtdb.api :as xt]],
 :tests
 [{:doc ":biff/assert-query expansion",
   :eval
   (biff-tx-op
    {}
    [:biff/assert-query
     {:select :xt/id, :from :stuff}
     [{:xt/id 1, :x 1}]]),
   :result []}
  _
  {:doc ":biff/assert-query expansion empty results",
   :eval
   (biff-tx-op
    {}
    [:biff/assert-query {:select :xt/id, :from :stuff} []]),
   :result []}
  _
  {:doc ":biff/assert-query execution",
   :eval
   (t/with-node
    [node
     {:stuff
      [{:xt/id (t/uuid 1), :x 1}
       {:xt/id (t/uuid 3), :x 2}
       {:xt/id (t/uuid 5), :x 3}]}]
    (let
     [query
      {:select :*,
       :from :stuff,
       :where [:in :xt/id [(t/uuid 1) (t/uuid 3)]]}
      results
      (biffx/q node query)]
     (t/submit-tx node [[:biff/assert-query query results]])
     (t/submit-tx
      node
      [[:biff/assert-query query (conj results {:xt/id 4, :x 4})]])
     (xt/q node "select _id, committed from xt.txs"))),
   :result
   [{:xt/id 2, :committed true}
    {:xt/id 1, :committed true}
    {:xt/id 0, :committed true}]}
  _
  {:doc ":biff/upsert expansion",
   :eval
   (t/with-sqlite
    [conn
     {:feed
      [{:xt/id (t/uuid 1), :feed/url "https://example.com/feed1"}]}]
    (biff-tx-op
     {:biff/conn* conn}
     [:biff/upsert
      :feed
      [:feed/url]
      {:xt/id (t/uuid 2),
       :feed/url "https://example.com/feed1",
       :feed/title "New Title"}
      {:xt/id (t/uuid 4),
       :feed/url "https://example.com/feed2",
       :feed/title "Feed 2"}
      {:feed/url "https://example.com/feed3", :feed/title "Feed 3"}])),
   :result
   [[:put-docs
     :feed
     {:xt/id #uuid "00040000-0000-0000-0000-000000000004",
      :feed/url "https://example.com/feed2",
      :feed/title "Feed 2"}
     {:xt/id #uuid "a32dc9f6-4f1d-f03a-8ce9-70b71df42503",
      :feed/url "https://example.com/feed3",
      :feed/title "Feed 3"}]
    {:xt nil,
     :sqlite
     {:update :feed,
      :set {:feed/title "New Title"},
      :where [:= :id #bytes "00010000000000000000000000000001"]}}]}
  _
  {:doc ":biff/upsert :on-insert / :on-update",
   :eval
   (t/with-sqlite
    [conn
     {:feed
      [{:xt/id (t/uuid 1), :feed/url "https://example.com/feed1"}]}]
    (biff-tx-op
     {:biff/conn* conn}
     [:biff/upsert
      :feed
      [:feed/url]
      {:xt/id (t/uuid 2),
       :feed/url "https://example.com/feed1",
       :biff/on-insert {:feed/title "Inserted"},
       :biff/on-update {:feed/title "Updated"}}
      {:xt/id (t/uuid 4),
       :feed/url "https://example.com/feed2",
       :biff/on-insert {:feed/title "New Feed"},
       :biff/on-update {:feed/title "Existing"}}])),
   :result
   [[:put-docs
     :feed
     {:xt/id #uuid "00040000-0000-0000-0000-000000000004",
      :feed/url "https://example.com/feed2",
      :feed/title "New Feed"}]
    {:xt nil,
     :sqlite
     {:update :feed,
      :set {:feed/title "Updated"},
      :where [:= :id #bytes "00010000000000000000000000000001"]}}]}
  _]}
