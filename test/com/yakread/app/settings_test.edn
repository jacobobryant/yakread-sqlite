{:require
 [[com.yakread.lib.test :as t] [com.yakread.app.settings :refer :all]],
 :tests
 [{:doc "save-settings writes digest days and timezone to user",
   :eval
   (t/test-route
    save-settings
    :post
    {:session {:uid "user1"},
     :biff.form/params
     {:user/digest-days #{:wednesday :friday :monday},
      :user/send-digest-at 8,
      :user/timezone "America/New_York",
      :user/use-original-links true}}),
   :result
   {:biff.fx/sqlite
    [{:update :user,
      :set
      {:user/use-original-links true,
       :user/digest-days #{:wednesday :friday :monday},
       :user/send-digest-at 8,
       :user/timezone "America/New_York"},
      :where [:= :user/id "user1"]}],
    :status 303,
    :headers {"location" ["/settings" nil]}}}
  _
  {:doc "save-settings defaults use-original-links to false",
   :eval
   (t/test-route
    save-settings
    :post
    {:session {:uid "user1"},
     :biff.form/params
     {:user/digest-days #{:tuesday},
      :user/send-digest-at 14,
      :user/timezone "America/Denver"}}),
   :result
   {:biff.fx/sqlite
    [{:update :user,
      :set
      {:user/use-original-links false,
       :user/digest-days #{:tuesday},
       :user/send-digest-at 14,
       :user/timezone "America/Denver"},
      :where [:= :user/id "user1"]}],
    :status 303,
    :headers {"location" ["/settings" nil]}}}
  _
  {:doc "set-timezone writes timezone to user",
   :eval
   (t/test-route
    set-timezone
    :post
    {:session {:uid "user1"},
     :biff.form/params {:user/timezone "Europe/London"}}),
   :result
   {:biff.fx/sqlite
    [{:update :user,
      :set {:user/timezone "Europe/London"},
      :where [:= :user/id "user1"]}],
    :status 204}}
  _]}
