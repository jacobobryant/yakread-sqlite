{:require
 [[com.yakread.lib.test :as t]
  [com.yakread.app.subscriptions :refer :all]],
 :tests
 [{:doc "unsubscribe feed subscription deletes the sub",
   :eval
   (t/test-route
    unsubscribe
    :post
    {:biff/now (t/instant 2000),
     :biff.fx/result
     {:params/sub
      {:sub/id "sub1", :sub/record-type :sub.record-type/feed}}}),
   :result
   {:status 204,
    :headers {"HX-Location" ["/subscriptions" nil]},
    :biff.fx/sqlite
    [:biff.fx/sqlite
     [{:delete-from :mv-sub, :where [:= :mv-sub/sub-id "sub1"]}
      {:delete-from :sub, :where [:= :sub/id "sub1"]}]]}}
  _
  {:doc "unsubscribe email subscription with one-click URL",
   :eval
   (t/test-route
    unsubscribe
    :post
    {:biff/now (t/instant 2000),
     :biff.fx/result
     {:params/sub
      {:sub/id "sub1",
       :sub/record-type :sub.record-type/email,
       :sub/latest-item
       {:item/id "item1",
        :item/email-list-unsubscribe "<https://example.com/unsub>",
        :item/email-list-unsubscribe-post
        "List-Unsubscribe=One-Click"}}}}),
   :result
   {:status 204,
    :headers {"HX-Location" ["/subscriptions" nil]},
    :biff.fx/sqlite
    [:biff.fx/sqlite
     [{:update :sub,
       :set
       {:sub/email-unsubscribed-at
        #time/instant "2000-01-01T00:00:00Z"},
       :where [:= :sub/id "sub1"]}]],
    :biff.fx/http
    [:biff.fx/http
     {:url "https://example.com/unsub",
      :method :post,
      :throw-exceptions false}]}}
  _
  {:doc "unsubscribe email subscription with mailto",
   :eval
   (t/test-route
    unsubscribe
    :post
    {:biff/now (t/instant 2000),
     :biff.fx/result
     {:params/sub
      {:sub/id "sub1",
       :sub/record-type :sub.record-type/email,
       :sub/latest-item
       {:item/id "item1",
        :item/email-list-unsubscribe "<mailto:unsub@example.com>"}}}}),
   :result
   {:status 204,
    :headers {"HX-Location" ["/subscriptions" nil]},
    :biff.fx/sqlite
    [:biff.fx/sqlite
     [{:update :sub,
       :set
       {:sub/email-unsubscribed-at
        #time/instant "2000-01-01T00:00:00Z"},
       :where [:= :sub/id "sub1"]}]],
    :biff.fx/email
    [:biff.fx/email
     {:to [{:email "unsub@example.com"}],
      :subject "unsubscribe",
      :text "unsubscribe"}]}}
  _
  {:doc "unsubscribe email subscription with URL (non-one-click)",
   :eval
   (t/test-route
    unsubscribe
    :post
    {:biff/now (t/instant 2000),
     :biff.fx/result
     {:params/sub
      {:sub/id "sub1",
       :sub/record-type :sub.record-type/email,
       :sub/latest-item
       {:item/id "item1",
        :item/email-list-unsubscribe
        "<https://example.com/unsub>"}}}}),
   :result
   {:status 204,
    :headers
    {"HX-Location" ["/subscriptions" nil],
     "HX-Trigger"
     "{\"yak/open-new-tab\":\"https://example.com/unsub\"}"},
    :biff.fx/sqlite
    [:biff.fx/sqlite
     [{:update :sub,
       :set
       {:sub/email-unsubscribed-at
        #time/instant "2000-01-01T00:00:00Z"},
       :where [:= :sub/id "sub1"]}]]}}
  _
  {:doc "resubscribe moves subs back",
   :eval
   (t/test-route
    resubscribe
    :post
    {:biff.fx/result
     {:params.checked/subscriptions
      [{:sub/id "sub1"} {:sub/id "sub2"}]}}),
   :result
   {:biff.fx/sqlite
    [:biff.fx/sqlite
     [{:update :sub,
       :set {:sub/email-unsubscribed-at nil},
       :where [:in :sub/id ["sub1" "sub2"]]}]],
    :status 204,
    :headers {"HX-Redirect" ["/subscriptions/unsubscribed" nil]}}}
  _]}
