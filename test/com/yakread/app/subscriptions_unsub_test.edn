{:require
 [[com.yakread.lib.test :as t]
  [com.yakread.app.subscriptions :refer :all]],
 :tests
 [{:doc "unsubscribe feed subscription deletes the sub",
   :eval
   (t/test-route
    unsubscribe
    :post
    {:biff/now (t/zdt 2000),
     :biff.fx/pathom
     {:params/sub {:sub/id "sub1", :sub/doc-type :sub/feed}}}),
   :result
   {:status 204,
    :headers {"HX-Location" ["/subscriptions" nil]},
    :biff.fx/tx [{:delete-from :sub, :where [:= :xt/id "sub1"]}]}}
  _
  {:doc "unsubscribe email subscription with one-click URL",
   :eval
   (t/test-route
    unsubscribe
    :post
    {:biff/now (t/zdt 2000),
     :biff.fx/pathom
     {:params/sub
      {:sub/id "sub1",
       :sub/doc-type :sub/email,
       :sub/latest-item
       {:item/id "item1",
        :item.email/list-unsubscribe "<https://example.com/unsub>",
        :item.email/list-unsubscribe-post
        "List-Unsubscribe=One-Click"}}}}),
   :result
   {:status 204,
    :headers {"HX-Location" ["/subscriptions" nil]},
    :biff.fx/tx
    [[:patch-docs
      :sub
      {:xt/id "sub1",
       :sub.email/unsubscribed-at
       #time/zoned-date-time "2000-01-01T00:00Z[UTC]"}]],
    :biff.fx/http
    {:url "https://example.com/unsub",
     :method :post,
     :throw-exceptions false}}}
  _
  {:doc "unsubscribe email subscription with mailto",
   :eval
   (t/test-route
    unsubscribe
    :post
    {:biff/now (t/zdt 2000),
     :biff.fx/pathom
     {:params/sub
      {:sub/id "sub1",
       :sub/doc-type :sub/email,
       :sub/latest-item
       {:item/id "item1",
        :item.email/list-unsubscribe "<mailto:unsub@example.com>"}}}}),
   :result
   {:status 204,
    :headers {"HX-Location" ["/subscriptions" nil]},
    :biff.fx/tx
    [[:patch-docs
      :sub
      {:xt/id "sub1",
       :sub.email/unsubscribed-at
       #time/zoned-date-time "2000-01-01T00:00Z[UTC]"}]],
    :biff.fx/email {:to "unsub@example.com", :subject "unsubscribe"}}}
  _
  {:doc "unsubscribe email subscription with URL (non-one-click)",
   :eval
   (t/test-route
    unsubscribe
    :post
    {:biff/now (t/zdt 2000),
     :biff.fx/pathom
     {:params/sub
      {:sub/id "sub1",
       :sub/doc-type :sub/email,
       :sub/latest-item
       {:item/id "item1",
        :item.email/list-unsubscribe
        "<https://example.com/unsub>"}}}}),
   :result
   {:status 204,
    :headers
    {"HX-Location" ["/subscriptions" nil],
     "HX-Trigger"
     "{\"yak/open-new-tab\":\"https://example.com/unsub\"}"},
    :biff.fx/tx
    [[:patch-docs
      :sub
      {:xt/id "sub1",
       :sub.email/unsubscribed-at
       #time/zoned-date-time "2000-01-01T00:00Z[UTC]"}]]}}
  _
  {:doc "resubscribe moves subs back",
   :eval
   (t/test-route
    resubscribe
    :post
    {:biff.fx/pathom
     {:params.checked/subscriptions
      [{:sub/id "sub1"} {:sub/id "sub2"}]}}),
   :result
   {:biff.fx/tx
    [{:update :sub,
      :set {:sub.email/unsubscribed-at nil},
      :where [:in :xt/id ["sub1" "sub2"]]}],
    :status 204,
    :headers {"HX-Redirect" ["/subscriptions/unsubscribed" nil]}}}
  _]}
