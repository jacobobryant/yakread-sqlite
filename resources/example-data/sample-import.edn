  :xtdb.api/tx-ops
  [[:xtdb.api/put
    {:xt/id #uuid "000e0000-0000-0000-0000-000000000001"
     :mv.sub/sub #uuid "00030000-0000-0000-0000-000000000001"
     :mv.sub/affinity-low 0.3
     :mv.sub/affinity-high 0.85
     :mv.sub/last-published #inst "2024-01-26T11:00:00Z"
