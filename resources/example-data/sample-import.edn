;; Example data for testing the SQLite import migration
;; This file mimics the structure of the nippy files in storage/migrate-export/
;; which are exported by com.biffweb.migrate.xtdb1/export!
;;
;; Each file contains a vector of XTDB v1 transactions.
;; Each transaction is a map with:
;;   - :xtdb.api/tx-ops - vector of transaction operations
;;   - :xtdb.api/tx-time - the transaction timestamp
;;
;; Transaction operations are vectors like:
;;   [:xtdb.api/put <document>]
;;   [:xtdb.api/delete <doc-id>]
;;
;; Usage:
;;   (require '[com.yakread.lib.migrate.sqlite.copilot :as copilot])
;;   (copilot/import-from-edn! {:conn sqlite-conn
;;                               :edn-file "resources/example-data/sample-import.edn"})

[;; Transaction 1: Create users
 {:xtdb.api/tx-time #inst "2024-01-01T10:00:00Z"
  :xtdb.api/tx-ops
  [[:xtdb.api/put
    {:xt/id #uuid "00010000-0000-0000-0000-000000000001"
     :user/email "alice@example.com"
     :user/roles #{:admin}
     :user/joined-at #inst "2024-01-01T10:00:00Z"
     :user/digest-days #{:monday :wednesday :friday}
     :user/timezone* "America/New_York"
     :user/from-the-sample false
     :user/use-original-links true
     :user/email-username "alice"}]
   [:xtdb.api/put
    {:xt/id #uuid "00010000-0000-0000-0000-000000000002"
     :user/email "bob@example.com"
     :user/joined-at #inst "2024-01-15T14:30:00Z"
     :user/timezone* "Europe/London"
     :user/plan :annual}]]}

 ;; Transaction 2: Create feeds
 {:xtdb.api/tx-time #inst "2024-01-02T08:00:00Z"
  :xtdb.api/tx-ops
  [[:xtdb.api/put
    {:xt/id #uuid "00020000-0000-0000-0000-000000000001"
     :feed/url "https://example.com/blog/feed.xml"
     :feed/synced-at #inst "2024-02-01T08:00:00Z"
     :feed/title "Example Blog"
     :feed/description "A blog about various topics"
     :feed/moderation :approved}]
   [:xtdb.api/put
    {:xt/id #uuid "00020000-0000-0000-0000-000000000002"
     :feed/url "https://news.ycombinator.com/rss"
     :feed/synced-at #inst "2024-02-01T07:00:00Z"
     :feed/title "Hacker News"
     :feed/moderation :approved}]]}

 ;; Transaction 3: Create subscriptions
 {:xtdb.api/tx-time #inst "2024-01-05T11:00:00Z"
  :xtdb.api/tx-ops
  [;; Feed subscriptions
   [:xtdb.api/put
    {:xt/id #uuid "00030000-0000-0000-0000-000000000001"
     :sub/user #uuid "00010000-0000-0000-0000-000000000001"
     :sub/created-at #inst "2024-01-05T11:00:00Z"
     :sub/pinned-at #inst "2024-01-10T09:00:00Z"
     :sub.feed/feed #uuid "00020000-0000-0000-0000-000000000001"}]
   [:xtdb.api/put
    {:xt/id #uuid "00030000-0000-0000-0000-000000000002"
     :sub/user #uuid "00010000-0000-0000-0000-000000000001"
     :sub/created-at #inst "2024-01-06T12:00:00Z"
     :sub.feed/feed #uuid "00020000-0000-0000-0000-000000000002"}]
   ;; Email subscription
   [:xtdb.api/put
    {:xt/id #uuid "00030000-0000-0000-0000-000000000003"
     :sub/user #uuid "00010000-0000-0000-0000-000000000001"
     :sub/created-at #inst "2024-01-20T15:00:00Z"
     :sub.email/from "newsletter@techweekly.com"}]]}

