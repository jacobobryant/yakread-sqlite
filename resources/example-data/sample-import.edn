    {:xt/id #uuid "00090000-0000-0000-0000-000000000002"
     :user-item/user #uuid "00010000-0000-0000-0000-000000000001"
     :user-item/item #uuid "00050000-0000-0000-0000-000000000002"
     :user-item/viewed-at #inst "2024-01-26T12:00:00Z"
     :user-item/bookmarked-at #inst "2024-01-26T12:10:00Z"}]
   [:xtdb.api/put
    {:xt/id #uuid "00090000-0000-0000-0000-000000000003"
     :user-item/user #uuid "00010000-0000-0000-0000-000000000001"
     :user-item/item #uuid "00050000-0000-0000-0000-000000000003"
     :user-item/viewed-at #inst "2024-01-27T10:00:00Z"
     :user-item/disliked-at #inst "2024-01-27T10:01:00Z"}]]}

 ;; Transaction 6: Digest with old schema (icymi/discover embedded)
 {:xtdb.api/tx-time #inst "2024-01-28T08:00:00Z"
  :xtdb.api/tx-ops
  [[:xtdb.api/put
    {:xt/id #uuid "000a0000-0000-0000-0000-000000000001"
     :digest/user #uuid "00010000-0000-0000-0000-000000000001"
     :digest/sent-at #inst "2024-01-28T08:00:00Z"
     :digest/subject #uuid "00050000-0000-0000-0000-000000000001"
     :digest/icymi [#uuid "00050000-0000-0000-0000-000000000002"]
     :digest/discover [#uuid "00050000-0000-0000-0000-000000000003"]}]]}

 ;; Transaction 7: Reclist with old schema (skip/items embedded)
 {:xtdb.api/tx-time #inst "2024-01-27T10:00:00Z"
  :xtdb.api/tx-ops
  [[:xtdb.api/put
    {:xt/id #uuid "000d0000-0000-0000-0000-000000000001"
     :skip/user #uuid "00010000-0000-0000-0000-000000000001"
     :skip/timeline-created-at #inst "2024-01-27T10:00:00Z"
     :skip/clicked #{#uuid "00050000-0000-0000-0000-000000000003"}
     :skip/items [#uuid "00050000-0000-0000-0000-000000000001"
                  #uuid "00050000-0000-0000-0000-000000000002"]}]]}

