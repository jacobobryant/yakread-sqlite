     :item/title "Getting Started with Clojure"
     :item/url "https://example.com/blog/clojure-intro"
     :item/published-at #inst "2024-01-24T08:00:00Z"
     :item/excerpt "Learn the basics of Clojure programming..."
     :item/author-name "Alice Smith"
     :item/lang "en"
     :item/length 2500
     :item.feed/feed #uuid "00020000-0000-0000-0000-000000000001"
     :item.feed/guid "clojure-intro-2024"}]
   [:xtdb.api/put
    {:xt/id #uuid "00050000-0000-0000-0000-000000000002"
     :item/ingested-at #inst "2024-01-26T11:00:00Z"
     :item/title "Why Functional Programming Matters"
     :item/url "https://example.com/blog/fp-matters"
     :item/published-at #inst "2024-01-25T09:00:00Z"
     :item/excerpt "Functional programming has many benefits..."
     :item/author-name "Bob Jones"
     :item/lang "en"
     :item/length 3200
     :item.feed/feed #uuid "00020000-0000-0000-0000-000000000001"
     :item.feed/guid "fp-matters-2024"}]
   [:xtdb.api/put
    {:xt/id #uuid "00050000-0000-0000-0000-000000000003"
