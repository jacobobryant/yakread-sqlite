     :item/published-at #inst "2024-01-27T08:00:00Z"
     :item.feed/feed #uuid "00020000-0000-0000-0000-000000000002"
     :item.feed/guid "hn-12345"}]
   ;; Email item
   [:xtdb.api/put
    {:xt/id #uuid "00050000-0000-0000-0000-000000000004"
     :item/ingested-at #inst "2024-01-28T14:00:00Z"
     :item/title "Tech Weekly Newsletter #42"
     :item/excerpt "This week in tech..."
     :item.email/sub #uuid "00030000-0000-0000-0000-000000000003"
     :item.email/raw-content-key #uuid "00070000-0000-0000-0000-000000000001"
     :item.email/list-unsubscribe "mailto:unsubscribe@techweekly.com"}]
   ;; Direct (bookmarked) item
   [:xtdb.api/put
    {:xt/id #uuid "00050000-0000-0000-0000-000000000005"
     :item/ingested-at #inst "2024-01-29T16:00:00Z"
     :item/title "An Interesting Article I Found"
     :item/url "https://interesting-site.com/article"
     :item/doc-type :item/direct
     :item.direct/candidate-status :approved}]]}

