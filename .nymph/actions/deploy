#!/bin/bash
set -e
source config.env

# Install Tailwind CSS standalone CLI if not present
TAILWIND_BIN="/usr/local/bin/tailwindcss"
if [ ! -f "$TAILWIND_BIN" ]; then
  echo "Installing Tailwind CSS..."
  curl -fsSL -o "$TAILWIND_BIN" https://github.com/tailwindlabs/tailwindcss/releases/download/v3.4.17/tailwindcss-linux-x64
  chmod +x "$TAILWIND_BIN"
fi

# Compile CSS with Tailwind
mkdir -p target/resources/public/css
tailwindcss \
  -c resources/tailwind.config.js \
  -i resources/tailwind.css \
  -o target/resources/public/css/main.css \
  --minify

rsync -av --relative \
  "--include='**.gitignore'" \
  "--exclude='/.git'" \
  "--filter=:- .gitignore" \
  --delete-after --protocol=29 \
  $(git ls-files) \
  target/resources/public/css/main.css \
  $APP_NAME@$SERVER:repo/
scp config.env $APP_NAME@$SERVER:repo/config.env
ssh $APP_NAME@$SERVER sudo systemctl reset-failed $APP_NAME.service
ssh $APP_NAME@$SERVER sudo systemctl restart $APP_NAME
